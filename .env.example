# Alma API Configuration
# Replace with your actual Alma API key
ALMA_API_KEY=your_api_key_here
ALMA_API_URL=https://api-na.hosted.exlibrisgroup.com

# Alma API Region
# Valid values: America, Europe, Asia Pacific, Canada, China
# Default: America (North America)
ALMA_API_REGION=America

# Alma Domain (for IIIF manifest URLs)
# This is your institution's Alma subdomain (e.g., 'grinnell' for grinnell.alma.exlibrisgroup.com)
# For sandbox or institutions without custom domain, use regional default: na01, eu01, ap01, ca01, or cn01
ALMA_DOMAIN=na01

# Alma Institution Code (required for regional/sandbox IIIF URLs)
# Format: NN[INST_NAME]_INST (e.g., '01GRINNELL_INST')
# Leave blank if using a custom domain
ALMA_INSTITUTION_CODE=

# Thumbnail Folder Path (for Function 14a)
# Path to folder containing .clientThumb thumbnail files
# Can be absolute or relative path
THUMBNAIL_FOLDER_PATH=/Volumes/DGIngest/Migration-to-Alma/exports/alumni-oral-histories/OBJ

# ============================================
# Selenium/Firefox Setup for Function 14b
# ============================================
# Function 14b uses Selenium to upload thumbnails via the Alma web interface.
# 
# Required software:
#   1. Firefox web browser
#   2. GeckoDriver: brew install geckodriver (macOS)
#
# See FUNCTION_14b_UPLOAD_THUMBNAILS.md for detailed instructions.
# ============================================

# ============================================
# Automatic SSO Login (Optional)
# ============================================
# If these credentials are set, Functions 11b and 14b will automatically log you in
# via Grinnell SSO. You'll still need to manually approve DUO authentication.
#
# Leave blank for manual login (default behavior)
# ============================================
SSO_USERNAME=
SSO_PASSWORD=

# ============================================
# ExLibris S3 / AWS Configuration (Function 11)
# ============================================
# CSV file containing MMS IDs and local TIFF file paths
TIFF_CSV_FILE=single_tiff_objects_20260320_121506.csv

# Local TIFF search path for Function 11
# Function 11 searches recursively under this path for TIFF files
# Example: /Volumes/Acasis1TB or /path/to/your/tiff/storage
LOCAL_TIFF_PATH=/Volumes/Acasis1TB
# Function 11 (API method) uploads JPG files to the ExLibris-managed AWS S3
# bucket and then references the file path in the Alma Representations API.
# Based on the Harvard/Corinna spec for Alma Digital API.
#
# ALMA_S3_BUCKET: ExLibris S3 bucket hostname
#   Production:  na-st01.ext.exlibrisgroup.com
#   Sandbox:     na-test-st01.ext.exlibrisgroup.com
#
# AWS credentials for the ExL S3 bucket (from your ExLibris/Alma administrator)
# ============================================
ALMA_S3_BUCKET=na-st01.ext.exlibrisgroup.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
